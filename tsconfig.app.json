{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": [
        "env.d.ts",
        "src/**/*",
        "src/**/*.vue"
    ],
    "exclude": [
        "src/**/__tests__/*"
    ],
    "compilerOptions": {
        "types": [
            "vuetify"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    }
}